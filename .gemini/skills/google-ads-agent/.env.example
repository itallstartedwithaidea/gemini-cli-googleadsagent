# Google Ads AI Agent — Credential Template
# ==========================================
# Copy this file to .env and fill in your values.
# Full setup guide: https://googleadsagent.ai/setup/
#
# You need 5 values from 3 places:
#   - Google Ads (ads.google.com → Tools → API Center)
#   - Google Cloud Console (console.cloud.google.com → APIs & Services → Credentials)
#   - OAuth Playground (developers.google.com/oauthplayground)

# --- From Google Ads (Tools & Settings → API Center) ---
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token-here
GOOGLE_ADS_LOGIN_CUSTOMER_ID=123-456-7890

# --- From Google Cloud Console (APIs & Services → Credentials → OAuth client) ---
GOOGLE_ADS_CLIENT_ID=123456789-abc.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=GOCSPX-your-client-secret-here

# --- From OAuth Playground (developers.google.com/oauthplayground) ---
GOOGLE_ADS_REFRESH_TOKEN=1//your-refresh-token-here
